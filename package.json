{
  "name": "@initia/mcp",
  "version": "0.1.2",
  "description": "An MCP control plane for the Initia's interwoven ecosystem",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "initia-mcp": "./dist/index.js",
    "initctl": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:all": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/ tests/ && tsc --noEmit",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "vitest run --exclude tests/smoke.test.ts",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "test:watch": "vitest --exclude tests/smoke.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "initia",
    "blockchain"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@initia/initia.js": "2.0.0-rc.3",
    "@initia/ledger-key": "2.0.0-rc.2",
    "@ledgerhq/hw-transport-node-hid": "^6.32.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "citty": "^0.2.1",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "overrides": {}
}
